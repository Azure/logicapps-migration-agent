{
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2024-03-31/trackingdefinitionschema.json#",
    "businessProcess": {
        "name": "OrderReceiving",
        "version": "@{parameters('VersionForBusinessProcess-OrderReceiving-Parameters')}",
        "correlationPropertyName": "OrderNumber"
    },
    "trackingDefinitions": {
        "PurchaseOrder": {
            "events": {
                "Received": {
                    "statuses": {
                        "success": {
                            "operationType": "trigger",
                            "operationName": "manual",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber",
                                "Product": "@trigger().outputs.body.Product",
                                "Quantity": "@trigger().outputs.body.Quantity",
                                "State": "@trigger().outputs.body.Address.State",
                                "City": "@trigger().outputs.body.Address.City",
                                "Client": "@concat('Client: ', parameters('client'))"
                            }
                        }
                    }
                },
                "Processing": {
                    "statuses": {
                        "success": {
                            "operationType": "action",
                            "operationName": "ApprovedPO",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber",
                                "ApprovalStatus": "@action().inputs.ApprovalStatus",
                                "ApproverName": "@action().inputs.ApproverName",
                                "POAmount": "@action().inputs.POamount",
                                "ClientCode": "@concat('Client Code: ', parameters('clientCode'))"
                            }
                        }
                    }
                },
                "Denied": {
                    "statuses": {
                        "success": {
                            "operationType": "action",
                            "operationName": "OrderDenied",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber"
                            }
                        }
                    }
                }
            }
        }
    }
}