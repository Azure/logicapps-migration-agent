{
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2024-03-31/trackingdefinitionschema.json#",
    "description": "Tracking definition of Logic App POProcessing for order processing business process",
    "businessProcess": {
        "name": "OrderProcessing-AdditionalDependencies",
        "version": "d52c9c91-6e10-4a90-9c1f-08ee5d01c656",
        "correlationPropertyName": "OrderNumber"
    },
    "trackingDefinitions": {
        "PurchaseOrder": {
            "events": {
                "Received": {
                    "statuses": {
                        "success": {
                            "operationType": "trigger",
                            "operationName": "manual",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber",
                                "Product": "@trigger().outputs.body.Product",
                                "Quantity": "@trigger().outputs.body.Quantity",
                                "State": "@trigger().outputs.body.Address.State",
                                "City": "@trigger().outputs.body.Address.City"
                            }
                        }
                    }
                },
                "Processing": {
                    "statuses": {
                        "success": {
                            "operationType": "action",
                            "operationName": "ApprovedPO",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber",
                                "ApprovalStatus": "@action().inputs.ApprovalStatus",
                                "ApproverName": "@action().inputs.ApproverName",
                                "POAmount": "@action().inputs.POamount",
                                "Body": "@body('PO_Received')",
                                "POAmountCompute": "@result('Compute_POAmount')"
                            }
                        },
                        "failure": {
                            "operationType": "action",
                            "operationName": "OrderDenied",
                            "properties": {
                                "OrderNumber": "@trigger().outputs.body.OrderNumber"
                            }
                        }
                    }
                }
            }
        },
        "Fulfilment": {
            "events": {
                "Shipped": {
                    "statuses": {
                        "success": {
                            "operationType": "action",
                            "operationName": "Invoke_a_workflow_in_this_workflow_app",
                            "properties": {
                                "OrderNumber": "@actions('Compose').inputs.OrderNumber",
                                "TrackingID": "@actions('Compose_2').inputs.TrackingID",
                                "ShipPriority": "@actions('Compose_2').inputs.Priority",
                                "Zip": "@actions('Parse_JSON').outputs.body.Address.Zip"
                            }
                        }
                    }
                }
            }
        },
        "Shipping": {
            "events": {
                "Completed": {
                    "statuses": {
                        "success": {
                            "operationType": "action",
                            "operationName": "Delivered",
                            "properties": {
                                "OrderNumber": "@action().inputs"
                            }
                        }
                    }
                }
            }
        }
    }
}