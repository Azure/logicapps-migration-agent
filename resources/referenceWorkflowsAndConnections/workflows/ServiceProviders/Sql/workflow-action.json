{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "actions": {
      "Sql_Action": {
        "type": "ServiceProvider",
        "runtimeConfiguration": "SqlWorkflow_RuntimeConfiguration",
        "inputs": {
          "parameters": "SqlWorkflow_Parameters",
          "serviceProviderConfiguration": {
            "connectionName": "SqlWorkflow_ConnectionName",
            "operationId": "SqlWorkflow_OperationId",
            "serviceProviderId": "/serviceProviders/sql"
          }
        },
        "runAfter": {}
      },
      "Response": {
        "type": "Response",
        "kind": "http",
        "inputs": {
          "statusCode": 200,
          "body": "@body('Sql_Action')"
        },
        "runAfter": {
          "Sql_Action": [
            "Succeeded",
            "Failed"
          ]
        }
      }
    },
    "triggers": {
      "manual": {
        "type": "Request",
        "kind": "Http",
        "inputs": {}
      }
    },
    "contentVersion": "1.0.0.0",
    "outputs": {}
  },
  "kind": "Stateful"
}