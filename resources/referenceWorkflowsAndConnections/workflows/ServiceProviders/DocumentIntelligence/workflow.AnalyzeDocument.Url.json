{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "actions": {
      "Get_Markdown": {
        "type": "ServiceProvider",
        "inputs": {
          "parameters": {
            "modelId": "prebuilt-layout",
            "modelIdInputs": {
              "url": "https://raw.githubusercontent.com/Azure-Samples/cognitive-services-REST-api-samples/master/curl/form-recognizer/rest-api/read.png",
              "outputContentType": "markdown"
            }
          },
          "serviceProviderConfiguration": {
            "connectionName": "docIntelligence",
            "operationId": "analyzeDocument",
            "serviceProviderId": "/serviceProviders/documentIntelligence"
          }
        },
        "runAfter": {
        }
      },
      "Response": {
        "inputs": {
          "body": "@body('Get_Markdown')",
          "statusCode": 200
        },
        "kind": "http",
        "runAfter": {
          "Get_Markdown": [
            "Succeeded"
          ]
        },
        "type": "Response"
      }
    },
    "contentVersion": "1.0.0.0",
    "outputs": {},
    "triggers": {
      "manual": {
        "kind": "http",
        "type": "request"
      }
    }
  },
  "kind": "Stateless"
}