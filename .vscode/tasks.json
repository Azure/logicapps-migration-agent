{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm: install",
            "type": "shell",
            "command": "npm install",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build",
            "dependsOn": ["npm: install", "npm: watch"],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "npm",
            "script": "watch",
            "problemMatcher": {
                "owner": "esbuild",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^\\s*(.+):(\\d+):(\\d+):\\s*$",
                    "file": 1,
                    "line": 2,
                    "column": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\[watch\\] build started$",
                    "endsPattern": "^\\[watch\\] build finished$"
                }
            },
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "label": "npm: watch"
        },
        {
            "type": "npm",
            "script": "compile",
            "problemMatcher": "$tsc",
            "label": "npm: compile"
        },
        {
            "type": "npm",
            "script": "lint",
            "problemMatcher": "$eslint-stylish",
            "label": "npm: lint"
        },
        {
            "type": "npm",
            "script": "build",
            "problemMatcher": [],
            "label": "npm: build"
        }
    ]
}
